-- ~/.config/hypr/monitors.lua.single
--===========================
-- MONITORS (single / laptop)
--===========================
local primary = "eDP-1"

hl.monitor({ output = primary, mode = "preferred", position = "auto", scale = 1 })

for i = 1, 8 do
    hl.workspace_rule({ workspace = tostring(i), monitor = primary, default = (i == 1) })
end
